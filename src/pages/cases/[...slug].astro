---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import { defaultLang, useTranslations } from '../../i18n/ui';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases
    .filter((entry) => entry.id.startsWith(`${defaultLang}/`))
    .map((entry) => ({
      params: { slug: entry.id.split('/').slice(1).join('/') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const lang = defaultLang;
const t = useTranslations(lang);
---

<Base
  lang={lang}
  title={`${entry.data.title} — ${t('brand.name')}`}
  description={entry.data.subtitle}
>
  <CaseStudy entry={entry} lang={lang} />
</Base>
