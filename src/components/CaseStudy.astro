---
import { render, type CollectionEntry } from 'astro:content';
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  entry: CollectionEntry<'cases'>;
  lang: Locale;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);
const d = entry.data;

// Group gallery items, preserving first-seen order of groups.
type Item = (typeof d.gallery)[number];
const groups: { name: string; items: Item[] }[] = [];
for (const item of d.gallery) {
  let g = groups.find((x) => x.name === item.group);
  if (!g) {
    g = { name: item.group, items: [] };
    groups.push(g);
  }
  g.items.push(item);
}

const meta = (
  [
    ['case.role', d.role],
    ['case.scope', d.scope],
    ['case.site', d.site],
    ['case.period', d.period],
  ] as const
).filter((row): row is [(typeof row)[0], string] => Boolean(row[1]));
---

<article class="case">
  <header class="case-hero">
    <img src={d.cover} alt={d.title} />
    <div class="case-hero__veil"></div>
    <div class="case-hero__cap">
      {d.tags.length > 0 && <p class="kicker">{d.tags.join(' · ')}</p>}
      <h1>{d.title}</h1>
      <p class="case-hero__sub">{d.subtitle}</p>
    </div>
  </header>

  {
    meta.length > 0 && (
      <dl class="meta">
        {meta.map(([key, v]) => (
          <div>
            <dt>{t(key)}</dt>
            <dd>{v}</dd>
          </div>
        ))}
      </dl>
    )
  }

  <div class="prose">
    <Content />
  </div>

  {
    groups.map((g) => (
      <section class="gallery-section">
        <h2 class="gallery-section__title">{g.name}</h2>
        <div class="gallery-grid">
          {g.items.map((it) => (
            <figure>
              <img src={it.src} alt={it.alt} loading="lazy" />
              {it.caption && <figcaption set:html={it.caption} />}
            </figure>
          ))}
        </div>
      </section>
    ))
  }

  {
    d.result && (
      <div class="prose">
        <h2>{t('case.result')}</h2>
        {d.result.split('\n\n').map((p) => (
          <p>{p}</p>
        ))}
      </div>
    )
  }
</article>
