---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "Network infrastructure & low-voltage systems — hands-on engineering portfolio of Oleg Petrov." } = Astro.props;
const year = 2026;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-head">
      <a class="brand" href="/">
        <span class="brand__name">Oleg Petrov</span>
        <span class="brand__role">Network Infrastructure &amp; Low-Voltage Systems</span>
      </a>
      <nav class="site-nav">
        <a href="/#work">Work</a>
        <a href="/#about">About</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <span>Oleg Petrov</span>
      <span class="muted">Network infrastructure · low-voltage · OT/IT</span>
      <span class="muted">© {year} olegpetrov.works</span>
    </footer>

    <style is:global>
      :root {
        --ink: #14181d; --graphite: #39414c; --muted: #6c7682; --faint: #9aa3ad;
        --line: #e4e7ea; --bg: #ffffff; --panel: #f5f6f8; --accent: #b5621f;
        --maxw: 1080px;
        --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --mono: "SF Mono", ui-monospace, Menlo, Consolas, monospace;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font-family: var(--font); font-size: 17px; line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; }
      img { display: block; max-width: 100%; }
      h1, h2, h3, h4 { margin: 0; font-weight: 650; letter-spacing: -0.02em; line-height: 1.15; }
      p { margin: 0 0 1em; color: var(--graphite); }
      .muted { color: var(--muted); }
      .mono { font-family: var(--mono); }

      /* ---- header / footer ---- */
      .site-head {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; max-width: var(--maxw); margin: 0 auto; padding: 22px 24px;
      }
      .brand { text-decoration: none; display: flex; flex-direction: column; line-height: 1.2; }
      .brand__name { font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .brand__role { font-size: 12px; color: var(--muted); }
      .site-nav { display: flex; gap: 22px; font-size: 14px; }
      .site-nav a { text-decoration: none; color: var(--graphite); }
      .site-nav a:hover { color: var(--accent); }
      .site-foot {
        max-width: var(--maxw); margin: 80px auto 0; padding: 24px;
        border-top: 1px solid var(--line); display: flex; flex-wrap: wrap; gap: 8px 24px;
        font-size: 13px; color: var(--graphite);
      }
      main { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

      .section-head {
        display: flex; align-items: baseline; gap: 12px;
        border-bottom: 1.5px solid var(--ink); padding-bottom: 8px; margin: 0 0 22px;
      }
      .section-head h2 { font-size: 24px; }

      /* ---- home ---- */
      .intro { padding: 28px 0 56px; max-width: 760px; }
      .intro h1 { font-size: 46px; margin-bottom: 14px; }
      .intro .lead { font-size: 20px; color: var(--ink); }
      .work, .about, .contact { padding: 30px 0; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 26px; }
      .card {
        text-decoration: none; border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
        background: #fff; transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
      }
      .card:hover { box-shadow: 0 10px 30px rgba(20,24,29,.10); transform: translateY(-2px); border-color: #d4d8dd; }
      .card__img { aspect-ratio: 16/10; overflow: hidden; background: var(--panel); }
      .card__img img { width: 100%; height: 100%; object-fit: cover; }
      .card__body { padding: 18px 18px 20px; }
      .card__body h3 { font-size: 19px; }
      .card__en { color: var(--faint); font-weight: 500; font-size: 14px; }
      .card__body p { font-size: 15px; margin: 8px 0 12px; }
      .card__tags { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); font-weight: 700; }

      /* ---- case page ---- */
      .case { padding-bottom: 20px; }
      .case-hero {
        position: relative; margin: 10px 0 0; border-radius: 10px; overflow: hidden;
        aspect-ratio: 16/9; background: var(--panel);
      }
      .case-hero img { width: 100%; height: 100%; object-fit: cover; }
      .case-hero__veil {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(10,13,16,.05), rgba(10,13,16,.15) 45%, rgba(10,13,16,.82));
      }
      .case-hero__cap { position: absolute; left: 0; right: 0; bottom: 0; padding: 28px 30px; color: #fff; }
      .kicker { font-size: 12px; letter-spacing: .2em; text-transform: uppercase; color: #f0c9a6; font-weight: 700; margin: 0 0 8px; }
      .case-hero__cap h1 { font-size: 40px; color: #fff; }
      .case-hero__sub { font-size: 17px; color: #e3e7ea; margin: 10px 0 0; max-width: 680px; }

      .meta {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 22px 0 0;
        border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
      }
      .meta > div { padding: 12px 16px; border-right: 1px solid var(--line); }
      .meta > div:last-child { border-right: 0; }
      .meta dt { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--faint); font-weight: 700; margin-bottom: 4px; }
      .meta dd { margin: 0; font-size: 14px; font-weight: 550; }

      .prose { max-width: 720px; margin: 48px auto 10px; }
      .prose h2 { font-size: 24px; margin: 40px 0 14px; padding-bottom: 8px; border-bottom: 1.5px solid var(--ink); }
      .prose h2:first-child { margin-top: 0; }
      .prose p { font-size: 17px; }
      .prose ul { padding-left: 20px; color: var(--graphite); }
      .prose li { margin: 0 0 8px; }
      .prose strong { color: var(--ink); }
      .prose blockquote {
        margin: 18px 0; padding: 4px 0 4px 16px; border-left: 2px solid var(--accent);
        color: var(--ink); font-style: italic;
      }

      .gallery-section { margin: 44px 0 0; }
      .gallery-section__title {
        font-size: 13px; letter-spacing: .16em; text-transform: uppercase; color: var(--accent);
        font-weight: 700; margin: 0 0 14px;
      }
      .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px; }
      .gallery-grid figure { margin: 0; }
      .gallery-grid img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 6px; background: var(--panel); }
      .gallery-grid figcaption { font-size: 13px; color: var(--muted); margin-top: 7px; line-height: 1.4; }

      @media (max-width: 720px) {
        body { font-size: 16px; }
        .intro h1 { font-size: 36px; }
        .case-hero { aspect-ratio: 3/2; }
        .case-hero__cap h1 { font-size: 28px; }
        .meta { grid-template-columns: repeat(2, 1fr); }
        .meta > div:nth-child(2) { border-right: 0; }
        .site-foot { gap: 4px 16px; }
      }
    </style>
  </body>
</html>
