---
import LangSwitcher from '../components/LangSwitcher.astro';
import {
  locales,
  defaultLang,
  stripLocale,
  localizeUrl,
  useTranslations,
  type Locale,
} from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description?: string;
}
const { lang, title, description } = Astro.props;
const t = useTranslations(lang);
const desc = description ?? t('home.description');
const year = 2026;

// SEO: canonical + hreflang alternates derived from the locale-stripped path.
const logical = stripLocale(Astro.url.pathname);
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternates = locales.map((l) => ({
  lang: l,
  href: new URL(localizeUrl(l, logical), Astro.site).href,
}));
const xDefault = new URL(localizeUrl(defaultLang, logical), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical.href} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-head">
      <a class="brand" href={localizeUrl(lang, '/')}>
        <span class="brand__name">{t('brand.name')}</span>
      </a>
      <div class="site-head__right">
        <nav class="site-nav">
          <a href={localizeUrl(lang, '/#work')}>{t('nav.work')}</a>
          <a href={localizeUrl(lang, '/#about')}>{t('nav.about')}</a>
          <a href={localizeUrl(lang, '/#contact')}>{t('nav.contact')}</a>
        </nav>
        <LangSwitcher />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <span>© {year} {t('brand.name')}</span>
      <span>olegpetrov.works</span>
    </footer>

    <style is:global>
      :root {
        --ink: #14181d; --graphite: #39414c; --muted: #6c7682; --faint: #9aa3ad;
        --line: #e4e7ea; --bg: #ffffff; --panel: #f5f6f8; --accent: #b5621f;
        --maxw: 1080px;
        --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --mono: "SF Mono", ui-monospace, Menlo, Consolas, monospace;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font-family: var(--font); font-size: 17px; line-height: 1.6;
        -webkit-font-smoothing: antialiased; overflow-x: hidden;
      }
      a { color: inherit; }
      img { display: block; max-width: 100%; }
      h1, h2, h3, h4 { margin: 0; font-weight: 650; letter-spacing: -0.02em; line-height: 1.15; }
      p { margin: 0 0 1em; color: var(--graphite); }
      .muted { color: var(--muted); }
      .mono { font-family: var(--mono); }

      /* ---- header / footer ---- */
      .site-head {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; max-width: var(--maxw); margin: 0 auto; padding: 20px 24px;
      }
      .brand { text-decoration: none; }
      .brand__name { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; color: var(--ink); }
      .site-head__right { display: flex; align-items: center; gap: 26px; }
      .site-nav { display: flex; gap: 24px; font-size: 14px; }
      .site-nav a { text-decoration: none; color: var(--muted); transition: color .15s ease; }
      .site-nav a:hover { color: var(--ink); }

      /* ---- language switcher ---- */
      .lang-switch { display: flex; align-items: center; gap: 8px; font-size: 13px; }
      .lang-switch__item {
        text-decoration: none; color: var(--faint); letter-spacing: .04em;
        font-weight: 600; transition: color .15s ease;
      }
      .lang-switch__item:hover { color: var(--graphite); }
      .lang-switch__item.is-active { color: var(--ink); }
      .lang-switch__sep { color: var(--line); }

      .site-foot {
        max-width: var(--maxw); margin: clamp(40px, 5vw, 60px) auto 0; padding: 22px 24px;
        border-top: 1px solid var(--line); display: flex; justify-content: space-between;
        flex-wrap: wrap; gap: 6px 24px; font-size: 13px; color: var(--faint);
      }
      main { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

      .section-head {
        display: flex; align-items: baseline; gap: 12px;
        border-bottom: 1.5px solid var(--ink); padding-bottom: 8px; margin: 0 0 22px;
      }
      .section-head h2 { font-size: 24px; }

      /* ---- home ---- */
      .intro { padding: 28px 0 56px; max-width: 760px; }
      .intro h1 { font-size: 46px; margin-bottom: 14px; }
      .intro .lead { font-size: 20px; color: var(--ink); }
      .work, .about, .contact { padding: 30px 0; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 26px; }
      .card {
        text-decoration: none; border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
        background: #fff; transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
      }
      .card:hover { box-shadow: 0 10px 30px rgba(20,24,29,.10); transform: translateY(-2px); border-color: #d4d8dd; }
      .card__img { aspect-ratio: 16/10; overflow: hidden; background: var(--panel); }
      .card__img img { width: 100%; height: 100%; object-fit: cover; }
      .card__body { padding: 18px 18px 20px; }
      .card__body h3 { font-size: 19px; }
      .card__en { color: var(--faint); font-weight: 500; font-size: 14px; }
      .card__body p { font-size: 15px; margin: 8px 0 12px; }
      .card__tags { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); font-weight: 700; }

      /* ---- case page: compact portfolio ---- */
      .case { padding-bottom: 8px; }
      .clabel { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--accent); font-weight: 700; margin: 0 0 16px; }

      .cwrap { max-width: 1000px; margin: 0 auto; }
      /* readable text measure (~72ch) for overview + result */
      .chead, .cdeliv, .cresult { max-width: 640px; }

      /* hero — the cover photograph, contained with generous margins */
      .chero {
        margin: clamp(14px, 2.5vw, 26px) 0 0; aspect-ratio: 4 / 3;
        overflow: hidden; border-radius: 10px; background: var(--panel);
      }
      .chero img { width: 100%; height: 100%; object-fit: cover; }

      /* title block — dominant, sits close under the hero */
      .chead { margin: clamp(16px, 2vw, 22px) 0 0; }
      .chead h1 { font-size: clamp(36px, 6vw, 58px); letter-spacing: -0.03em; line-height: 1.03; }
      .csub { font-size: clamp(17px, 1.9vw, 20px); color: var(--graphite); margin: 15px 0 0; line-height: 1.45; }
      .cmeta { font-size: 14px; color: var(--muted); margin: 18px 0 0; letter-spacing: .005em; }

      /* delivered */
      .cdeliv { margin: clamp(26px, 3.5vw, 38px) 0 0; }
      .cdeliv ul { list-style: none; padding: 0; margin: 0; }
      .cdeliv li { position: relative; padding-left: 22px; font-size: 16px; color: var(--graphite); margin: 0 0 11px; line-height: 1.5; }
      .cdeliv li:last-child { margin-bottom: 0; }
      .cdeliv li::before { content: ""; position: absolute; left: 0; top: 11px; width: 9px; height: 2px; background: var(--accent); }

      /* implementation — gallery as project documentation */
      .gsection { margin: clamp(48px, 7vw, 80px) 0 0; }
      .gsection .clabel { margin: 0 0 6px; }
      .gsub { font-size: 14px; color: var(--muted); margin: 0 0 20px; }
      .gallery {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin: 0;
      }
      .thumb {
        padding: 0; border: 0; margin: 0; cursor: pointer; overflow: hidden;
        border-radius: 10px; background: var(--panel); aspect-ratio: 1 / 1; display: block;
      }
      .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
      .thumb:hover img { transform: scale(1.05); }
      .thumb:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

      /* result — clear top break, tight ending */
      .cresult { margin: clamp(48px, 7vw, 80px) 0 0; }
      .cresult p { font-size: 17px; color: var(--graphite); }
      .cresult p:last-child { margin-bottom: 0; }
      .case { padding-bottom: 0; }

      /* lightbox */
      .lb {
        position: fixed; inset: 0; z-index: 60; display: none;
        align-items: center; justify-content: center; padding: 24px;
        background: rgba(8, 10, 12, .94); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px);
      }
      .lb.is-open { display: flex; }
      .lb__stage { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 14px; max-width: min(1180px, 94vw); }
      .lb__stage img { max-width: 94vw; max-height: 82vh; object-fit: contain; border-radius: 6px; }
      .lb__count { font-size: 13px; color: rgba(255,255,255,.55); font-variant-numeric: tabular-nums; letter-spacing: .04em; }
      .lb__btn { position: absolute; background: transparent; border: 0; color: #fff; cursor: pointer; opacity: .7; transition: opacity .15s ease; line-height: 1; }
      .lb__btn:hover { opacity: 1; }
      .lb__x { top: 16px; right: 20px; font-size: 30px; width: 44px; height: 44px; }
      .lb__nav { top: 50%; transform: translateY(-50%); font-size: 44px; width: 56px; height: 72px; }
      .lb__prev { left: 8px; } .lb__next { right: 8px; }

      @media (max-width: 900px) {
        .gallery { grid-template-columns: repeat(3, 1fr); }
      }
      @media (max-width: 720px) {
        body { font-size: 16px; }
        .intro h1 { font-size: 36px; }
        .chero { aspect-ratio: 3 / 2; }
        .gallery { grid-template-columns: repeat(2, 1fr); gap: 8px; }
        .lb__nav { font-size: 34px; width: 44px; }
        .site-foot { gap: 4px 16px; }
        .site-head { flex-wrap: wrap; gap: 10px 16px; }
        .site-head__right { gap: 16px; }
      }
    </style>
  </body>
</html>
