---
import LangSwitcher from '../components/LangSwitcher.astro';
import {
  locales,
  defaultLang,
  stripLocale,
  localizeUrl,
  useTranslations,
  type Locale,
} from '../i18n/ui';

interface Props {
  lang: Locale;
  title: string;
  description?: string;
}
const { lang, title, description } = Astro.props;
const t = useTranslations(lang);
const desc = description ?? t('home.description');
const year = 2026;

// SEO: canonical + hreflang alternates derived from the locale-stripped path.
const logical = stripLocale(Astro.url.pathname);
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternates = locales.map((l) => ({
  lang: l,
  href: new URL(localizeUrl(l, logical), Astro.site).href,
}));
const xDefault = new URL(localizeUrl(defaultLang, logical), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical.href} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-head">
      <a class="brand" href={localizeUrl(lang, '/')}>
        <span class="brand__name">{t('brand.name')}</span>
        <span class="brand__role">{t('brand.role')}</span>
      </a>
      <div class="site-head__right">
        <nav class="site-nav">
          <a href={localizeUrl(lang, '/#work')}>{t('nav.work')}</a>
          <a href={localizeUrl(lang, '/#about')}>{t('nav.about')}</a>
          <a href={localizeUrl(lang, '/#contact')}>{t('nav.contact')}</a>
        </nav>
        <LangSwitcher />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <span>{t('brand.name')}</span>
      <span class="muted">{t('footer.tagline')}</span>
      <span class="muted">© {year} olegpetrov.works</span>
    </footer>

    <style is:global>
      :root {
        --ink: #14181d; --graphite: #39414c; --muted: #6c7682; --faint: #9aa3ad;
        --line: #e4e7ea; --bg: #ffffff; --panel: #f5f6f8; --accent: #b5621f;
        --maxw: 1080px;
        --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        --mono: "SF Mono", ui-monospace, Menlo, Consolas, monospace;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--ink);
        font-family: var(--font); font-size: 17px; line-height: 1.6;
        -webkit-font-smoothing: antialiased; overflow-x: hidden;
      }
      a { color: inherit; }
      img { display: block; max-width: 100%; }
      h1, h2, h3, h4 { margin: 0; font-weight: 650; letter-spacing: -0.02em; line-height: 1.15; }
      p { margin: 0 0 1em; color: var(--graphite); }
      .muted { color: var(--muted); }
      .mono { font-family: var(--mono); }

      /* ---- header / footer ---- */
      .site-head {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; max-width: var(--maxw); margin: 0 auto; padding: 22px 24px;
      }
      .brand { text-decoration: none; display: flex; flex-direction: column; line-height: 1.2; }
      .brand__name { font-weight: 700; font-size: 17px; letter-spacing: -0.01em; }
      .brand__role { font-size: 12px; color: var(--muted); }
      .site-head__right { display: flex; align-items: center; gap: 22px; }
      .site-nav { display: flex; gap: 22px; font-size: 14px; }
      .site-nav a { text-decoration: none; color: var(--graphite); }
      .site-nav a:hover { color: var(--accent); }

      /* ---- language switcher ---- */
      .lang-switch { display: flex; align-items: center; gap: 8px; font-size: 13px; }
      .lang-switch__item {
        text-decoration: none; color: var(--faint); letter-spacing: .04em;
        font-weight: 600; transition: color .15s ease;
      }
      .lang-switch__item:hover { color: var(--graphite); }
      .lang-switch__item.is-active { color: var(--ink); }
      .lang-switch__sep { color: var(--line); }

      .site-foot {
        max-width: var(--maxw); margin: 80px auto 0; padding: 24px;
        border-top: 1px solid var(--line); display: flex; flex-wrap: wrap; gap: 8px 24px;
        font-size: 13px; color: var(--graphite);
      }
      main { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

      .section-head {
        display: flex; align-items: baseline; gap: 12px;
        border-bottom: 1.5px solid var(--ink); padding-bottom: 8px; margin: 0 0 22px;
      }
      .section-head h2 { font-size: 24px; }

      /* ---- home ---- */
      .intro { padding: 28px 0 56px; max-width: 760px; }
      .intro h1 { font-size: 46px; margin-bottom: 14px; }
      .intro .lead { font-size: 20px; color: var(--ink); }
      .work, .about, .contact { padding: 30px 0; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 26px; }
      .card {
        text-decoration: none; border: 1px solid var(--line); border-radius: 8px; overflow: hidden;
        background: #fff; transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
      }
      .card:hover { box-shadow: 0 10px 30px rgba(20,24,29,.10); transform: translateY(-2px); border-color: #d4d8dd; }
      .card__img { aspect-ratio: 16/10; overflow: hidden; background: var(--panel); }
      .card__img img { width: 100%; height: 100%; object-fit: cover; }
      .card__body { padding: 18px 18px 20px; }
      .card__body h3 { font-size: 19px; }
      .card__en { color: var(--faint); font-weight: 500; font-size: 14px; }
      .card__body p { font-size: 15px; margin: 8px 0 12px; }
      .card__tags { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); font-weight: 700; }

      /* ---- case page: engineering reportage ---- */
      .case { padding-bottom: 24px; }

      /* full-bleed cinematic hero */
      .hero {
        position: relative; margin-top: 6px;
        width: 100vw; margin-left: calc(50% - 50vw);
        aspect-ratio: 16/9; max-height: 80vh; overflow: hidden; background: var(--panel);
      }
      .hero img { width: 100%; height: 100%; object-fit: cover; }
      .hero__veil {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(10,13,16,0) 28%, rgba(10,13,16,.18) 52%, rgba(10,13,16,.80));
      }
      .hero__capwrap { position: absolute; inset: 0; display: flex; align-items: flex-end; }
      .hero__cap { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 24px 46px; color: #fff; }
      .kicker { font-size: 12px; letter-spacing: .22em; text-transform: uppercase; color: #f0c9a6; font-weight: 700; margin: 0 0 16px; }
      .hero__cap h1 { font-size: clamp(32px, 5.2vw, 56px); color: #fff; letter-spacing: -0.025em; }
      .hero__sub { font-size: clamp(16px, 1.8vw, 20px); color: #e7eaed; margin: 16px 0 0; max-width: 620px; line-height: 1.45; }

      /* facts — airy, borderless */
      .facts {
        display: flex; flex-wrap: wrap; gap: 26px 56px;
        margin: clamp(30px, 5vw, 56px) 0 0; padding: 0;
      }
      .facts > div { margin: 0; }
      .facts dt { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--faint); font-weight: 700; margin: 0 0 7px; }
      .facts dd { margin: 0; font-size: 16px; font-weight: 550; color: var(--ink); }

      /* prose — softened headings, more air, no rules */
      .prose { max-width: 680px; margin: clamp(40px, 6vw, 76px) auto 0; }
      .prose h2 {
        font-size: clamp(22px, 2.6vw, 27px); letter-spacing: -0.02em;
        margin: clamp(40px, 6vw, 66px) 0 16px; padding: 0; border: 0;
      }
      .prose h2::before {
        content: ""; display: block; width: 28px; height: 2px; border-radius: 2px;
        background: var(--accent); opacity: .9; margin-bottom: 18px;
      }
      .prose h2:first-child { margin-top: 0; }
      .prose p { font-size: 17px; }
      .prose ul { padding-left: 18px; color: var(--graphite); margin: 0 0 1em; }
      .prose li { margin: 0 0 10px; }
      .prose strong { color: var(--ink); }

      /* report — magazine flow of plates */
      .report { display: flex; flex-direction: column; gap: clamp(30px, 5vw, 72px); margin: clamp(46px, 7vw, 96px) 0; }
      .report .plate { margin: 0; }
      .report img { width: 100%; height: 100%; object-fit: cover; border-radius: 10px; background: var(--panel); }
      .band { display: grid; gap: clamp(14px, 2vw, 26px); align-items: start; }
      .band--half { grid-template-columns: repeat(2, 1fr); }
      .band--third { grid-template-columns: repeat(3, 1fr); }
      .band--half .plate img { aspect-ratio: 4/3; }
      .band--third .plate img { aspect-ratio: 3/4; }
      .plate--wide img { aspect-ratio: 16/9; }
      .plate--full { width: 100vw; margin-left: calc(50% - 50vw); }
      .plate--full img { aspect-ratio: 21/9; max-height: 86vh; border-radius: 0; }

      /* captions — light */
      .cap { font-size: 13px; color: var(--muted); margin-top: 11px; line-height: 1.5; max-width: 56ch; }
      .cap--center { max-width: var(--maxw); margin: 14px auto 0; padding: 0 24px; }

      /* closing — result paired with the app proof */
      .closing {
        display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(28px, 5vw, 64px);
        align-items: center; margin: clamp(50px, 8vw, 104px) 0 0;
      }
      .closing__kicker { font-size: 12px; letter-spacing: .18em; text-transform: uppercase; color: var(--accent); font-weight: 700; margin: 0 0 16px; }
      .closing__text p { font-size: 18px; color: var(--graphite); max-width: 46ch; }
      .closing__text p:last-child { margin-bottom: 0; }
      .closing__media { display: flex; justify-content: center; }
      .phone { margin: 0; max-width: 300px; }
      .phone img { width: 100%; border-radius: 18px; box-shadow: 0 18px 50px rgba(20,24,29,.16); background: var(--panel); }
      .phone .cap { text-align: center; max-width: none; margin-top: 14px; }

      @media (max-width: 720px) {
        body { font-size: 16px; }
        .intro h1 { font-size: 36px; }
        .hero { aspect-ratio: 3/2; max-height: 72vh; }
        .hero__cap { padding-bottom: 30px; }
        .facts { gap: 20px 40px; }
        .band--half, .band--third { grid-template-columns: 1fr; }
        .plate--full img { aspect-ratio: 3/2; }
        .closing { grid-template-columns: 1fr; gap: 32px; }
        .phone { max-width: 260px; }
        .site-foot { gap: 4px 16px; }
        .site-head { flex-wrap: wrap; gap: 10px 16px; }
        .site-head__right { gap: 16px; }
      }
    </style>
  </body>
</html>
